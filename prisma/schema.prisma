generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AnalysisRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  RETRY_WAIT
  CANCELLED
}

enum AnalysisTriggerSource {
  MANUAL
  CACHE
  WEBHOOK
  SCHEDULED
  INSTALLATION
}

enum GitHubInstallationStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum WebhookDeliveryStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  IGNORED
  RETRY_WAIT
  FAILED
}

model Repository {
  id              String   @id @default(cuid())
  githubId        BigInt?  @unique
  owner           String
  name            String
  fullName        String
  normalizedName  String   @unique
  htmlUrl         String?
  defaultBranch   String?
  primaryLanguage String?
  isArchived      Boolean  @default(false)
  isFork          Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastAnalyzedAt DateTime?

  analysisRuns AnalysisRun[]
  githubInstallations GitHubInstallationRepository[]

  @@index([owner, name])
  @@index([lastAnalyzedAt])
}

model AnalysisRun {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  status       AnalysisRunStatus
  progress     Int               @default(0)
  currentStep  String
  forceRefresh Boolean           @default(false)

  attemptCount Int @default(0)
  maxAttempts  Int @default(3)
  priority     Int @default(0)

  queuedAt    DateTime  @default(now())
  claimedAt   DateTime?
  heartbeatAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  availableAt DateTime  @default(now())

  workerId     String?
  errorCode    String?
  errorMessage String?

  triggerSource     AnalysisTriggerSource @default(MANUAL)
  triggerEvent      String?
  requestedSections Json?
  baseAnalysisRunId String?
  webhookDeliveryId String? @unique
  webhookDelivery   WebhookDelivery? @relation(fields: [webhookDeliveryId], references: [id], onDelete: SetNull)
  deduplicationKey  String? @unique
  analysisMode      String?

  report AnalysisReportRecord?
  events AnalysisEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, availableAt, priority, queuedAt])
  @@index([repositoryId, createdAt])
  @@index([heartbeatAt])
  @@index([triggerSource, analysisMode, status])
}

model AnalysisReportRecord {
  id            String      @id @default(cuid())
  analysisRunId String      @unique
  analysisRun   AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  schemaVersion String
  scoreVersion  String?
  generatedAt   DateTime

  healthScore Float?
  healthGrade String?
  confidence  String?

  collaborationScore   Float?
  activityScore        Float?
  automationScore      Float?
  projectHygieneScore  Float?

  analysisMode      String?
  triggerSource     AnalysisTriggerSource?
  triggerEvent      String?
  requestedSections Json?
  baseAnalysisRunId String?
  webhookDeliveryId String?

  reportJson Json

  createdAt DateTime @default(now())

  @@index([generatedAt])
  @@index([healthScore])
}

model AnalysisEvent {
  id            String      @id @default(cuid())
  analysisRunId String
  analysisRun   AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  eventType     String
  progress      Int?
  message       String
  metadata      Json?
  createdAt     DateTime    @default(now())

  @@index([analysisRunId, createdAt])
}

model GitHubInstallation {
  id                  String   @id @default(cuid())
  installationId      BigInt   @unique

  accountId           BigInt?
  accountLogin        String
  accountType         String?
  targetType          String?

  repositorySelection String?
  permissionsJson     Json?
  subscribedEvents    Json?

  status              GitHubInstallationStatus @default(ACTIVE)
  suspendedAt         DateTime?
  installedAt         DateTime?
  deletedAt           DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  repositories        GitHubInstallationRepository[]
  webhookDeliveries   WebhookDelivery[]

  @@index([accountLogin])
  @@index([status])
}

model GitHubInstallationRepository {
  id                    String   @id @default(cuid())

  installationDbId      String
  installation          GitHubInstallation @relation(fields: [installationDbId], references: [id], onDelete: Cascade)

  repositoryId          String
  repository            Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  githubRepositoryId    BigInt
  private               Boolean  @default(false)
  active                Boolean  @default(true)

  addedAt               DateTime @default(now())
  removedAt             DateTime?
  lastWebhookAt         DateTime?
  lastFullSyncAt        DateTime?

  automaticAnalysis     Boolean  @default(false)
  nextScheduledAt       DateTime?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([installationDbId, githubRepositoryId])
  @@index([repositoryId, active])
  @@index([automaticAnalysis, nextScheduledAt])
}

model WebhookDelivery {
  id                    String   @id @default(cuid())
  deliveryId            String   @unique

  eventName             String
  action                String?

  installationDbId      String?
  installation          GitHubInstallation? @relation(fields: [installationDbId], references: [id], onDelete: SetNull)

  githubInstallationId  BigInt?
  githubRepositoryId    BigInt?
  repositoryFullName    String?

  status                WebhookDeliveryStatus @default(RECEIVED)

  payloadHash           String
  normalizedPayload     Json?

  receivedAt            DateTime @default(now())
  claimedAt             DateTime?
  heartbeatAt           DateTime?
  processedAt           DateTime?
  failedAt              DateTime?

  workerId              String?
  attemptCount          Int      @default(0)
  maxAttempts           Int      @default(3)
  availableAt           DateTime @default(now())

  errorCode             String?
  errorMessage          String?
  processingMessage     String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  analysisRun           AnalysisRun?

  @@index([status, availableAt, receivedAt])
  @@index([githubRepositoryId, receivedAt])
  @@index([githubInstallationId])
}
