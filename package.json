{
  "name": "repopulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@repopulse/web",
    "dev:web": "npm run dev --workspace=@repopulse/web",
    "dev:api": "npm run dev --workspace=@repopulse/api",
    "dev:worker": "npm run dev --workspace=@repopulse/worker",
    "dev:services": "docker compose up -d postgres",
    "dev:all": "concurrently -n api,worker,web \"npm run dev:api\" \"npm run dev:worker\" \"npm run dev:web\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:seed": "npm run seed --workspace=@repopulse/database",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test:unit",
    "test:unit": "npm run test --workspaces --if-present",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css,html}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.14"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "concurrently": "^10.0.3",
    "prisma": "^7.8.0"
  }
}
